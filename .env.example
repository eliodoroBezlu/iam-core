# ══════════════════════════════════════════════
# IAM CORE — Variables de Entorno
# Copiar a .env y completar todos los valores
# ══════════════════════════════════════════════

# Aplicación
NODE_ENV=development
PORT=4000
APP_NAME=SanCristobal IAM

# Base de datos PostgreSQL
DATABASE_URL="postgresql://iam_user:iam_password@localhost:5432/iam_db?schema=public"

# JWT — Claves RSA (generadas con npm run keys:generate)
# Usar ruta absoluta al archivo .pem o pegar el contenido con \n
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Expiración de tokens
JWT_ACCESS_EXPIRY=900         # 15 minutos en segundos
JWT_REFRESH_EXPIRY=28800      # 8 horas en segundos
JWT_TEMP_EXPIRY=300           # 5 minutos para token temporal 2FA

# Issuer del JWT (dominio de producción)
JWT_ISSUER=iam-core
JWT_AUDIENCE=forms-service,iro-service

# Bcrypt
BCRYPT_ROUNDS=12

# CORS — orígenes permitidos separados por coma
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Cookie domain — SSO cross-subdominio.
# Déjalo VACÍO en local y en *.up.railway.app (cookies host-only).
# Cuando todos los servicios compartan un dominio propio, ponlo con punto inicial:
#   COOKIE_DOMAIN=.miempresa.com   → cookies compartidas entre auth/app/api.miempresa.com
COOKIE_DOMAIN=

# TOTP — clave de cifrado del secret (mínimo 32 chars)
TOTP_ENCRYPTION_KEY=cambia-esto-por-una-clave-segura-de-32-chars

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000   # 15 minutos
RATE_LIMIT_MAX=100            # requests por ventana

# Logging
LOG_LEVEL=info                # debug | info | warn | error

# Seed inicial (solo para desarrollo)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin@12345!
SEED_ADMIN_EMAIL=admin@empresa.com
SEED_ADMIN_FULLNAME=Administrador Sistema
